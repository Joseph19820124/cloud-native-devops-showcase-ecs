environment = "dev"
aws_region  = "us-east-1"

# REQUIRED: database password (do not commit the real file).
db_password = "change-me-please"

# Per-service image tags — normally set by CI/CD (or scripts/deploy.sh) to the
# commit SHA of the last change to each service. Leave unset to use "latest".
# backend_image_tag  = "<sha>"
# frontend_image_tag = "<sha>"

# Cheaper throwaway option: skip the NAT gateway and run tasks in public subnets.
# single_nat_gateway = false
# assign_public_ip   = true
